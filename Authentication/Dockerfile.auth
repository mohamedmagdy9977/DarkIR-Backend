FROM python:3.10-slim

WORKDIR /app

# Install dependencies
COPY requirements_auth.txt .
RUN pip install --no-cache-dir -r requirements_auth.txt

# Copy application code
COPY auth_server.py .
COPY database.py .
COPY models.py .
COPY security.py .
COPY config.py .

EXPOSE 8080

CMD ["python", "auth_server.py"]